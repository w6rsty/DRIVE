# Cloudflare Pages — tell the browser the .br files are pre-compressed
# Brotli, so it decompresses them on the fly. Required because the Unity
# build was made without "Decompression Fallback".

/Build/*.br
  Content-Encoding: br
  Cache-Control: public, max-age=31536000, immutable

/Build/*.wasm.br
  Content-Type: application/wasm

/Build/*.framework.js.br
  Content-Type: application/javascript

/Build/*.data.br
  Content-Type: application/octet-stream

# Hashed Addressables bundles are immutable — cache forever.
/StreamingAssets/aa/WebGL/*.bundle
  Cache-Control: public, max-age=31536000, immutable

# Cross-origin isolation. Harmless for this same-origin Unity build,
# and required if you ever enable WebGL multithreading / SharedArrayBuffer.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
