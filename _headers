# Tell the browser these files are pre-compressed with Brotli, so it
# decompresses them on the fly. Required because Unity build was made
# without "Decompression Fallback" — the loader expects the server to
# set Content-Encoding correctly.

/Build/*.data.br
  Content-Encoding: br
  Content-Type: application/octet-stream

/Build/*.wasm.br
  Content-Encoding: br
  Content-Type: application/wasm

/Build/*.framework.js.br
  Content-Encoding: br
  Content-Type: application/javascript

# Hashed Addressables bundles are immutable — cache forever.
/StreamingAssets/aa/WebGL/*.bundle
  Cache-Control: public, max-age=31536000, immutable
